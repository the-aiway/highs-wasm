{
  "name": "highs-wasm",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./st": "./dist/highs.st.mjs",
    "./mt": {
      "bun": "./dist/highs.mt.node.mjs",
      "node": "./dist/highs.mt.node.mjs",
      "default": "./dist/highs.mt.mjs"
    },
    "./debug": "./dist/highs.debug.mjs",
    "./native": {
      "bun": "./src/native.ts",
      "default": "./src/native.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.mjs",
  "files": [
    "dist/",
    "src/native.ts"
  ],
  "sideEffects": false,
  "scripts": {
    "build:wasm:st": "./build/build-st.sh",
    "build:wasm:mt": "./build/build-mt.sh",
    "build:wasm:mt-node": "./build/build-mt-node.sh",
    "build:wasm:debug": "./build/build-debug.sh",
    "build:wasm": "bun run build:wasm:st && bun run build:wasm:mt && bun run build:wasm:mt-node",
    "build:native": "./build/build-native.sh",
    "build:worker:st": "bun build ./src/worker-st.ts --outfile dist/worker.st.js --target browser --format esm --minify",
    "build:worker:mt": "bun build ./src/worker-mt.ts --outfile dist/worker.mt.js --target browser --format esm --minify",
    "build:worker": "bun run build:worker:st && bun run build:worker:mt",
    "build:js": "bun run build:worker && bun build ./src/index.ts --outdir dist --target browser --format esm --splitting --external '../dist/*.mjs' && mv dist/index.js dist/index.mjs && sed -i '' 's|../dist/highs|./highs|g' dist/index.mjs && cp src/index.ts dist/index.d.ts",
    "build": "bun run build:wasm && bun run build:js",
    "test": "bun test src/",
    "test:e2e": "bunx playwright test",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "playwright": "^1.58.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
